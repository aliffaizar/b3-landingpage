---
import mineWaste from "@/img/mine-waste.jpg"
import medicalWaste from "@/img/medical-waste.jpg"
import industrialWaste from "@/img/industial-waste.jpg"
import { Image } from "astro:assets"

const services = [
  {
    title: "Limbah Tambang",
    description:
      "Pengangkutan limbah hasil penambangan seperti tailing, lumpur pencucian, dan material berbahaya lainnya dengan standar keselamatan tinggi.",
    image: mineWaste,
  },
  {
    title: "Limbah Medis",
    description:
      "Pembuangan limbah infeksius, jarum suntik, dan limbah rumah sakit lainnya sesuai protokol kesehatan dan regulasi Kemenkes.",
    image: medicalWaste,
  },
  {
    title: "Limbah Industri",
    description:
      "Penanganan limbah B3 dari proses industri manufaktur, kimia, dan tekstil dengan dokumentasi lengkap dan kepatuhan regulasi.",
    image: industrialWaste,
  },
]
---

<section id="services" class="py-24">
  <div class="mx-auto max-w-7xl px-8">
    <div class="mb-16 text-center">
      <h2 class="mb-4 font-heading text-3xl font-bold tracking-tight text-foreground lg:text-4xl">
        Layanan Kami
      </h2>
      <p class="mx-auto mb-6 max-w-2xl text-muted-foreground">
        Tiga kategori utama limbah B3 yang kami tangani dengan profesional
        dan sesuai regulasi.
      </p>
      <div class="mx-auto h-1 w-20 rounded-full bg-primary"></div>
    </div>
    <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
      <div
        class="group relative overflow-hidden rounded-2xl bg-card shadow-sm transition-all duration-300 hover:shadow-xl"
      >
        <div class="relative h-48 overflow-hidden">
          <Image
            src={services[0].image}
            alt={services[0].title}
            class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent"></div>
          <div class="absolute bottom-4 left-4 flex h-12 w-12 items-center justify-center rounded-xl bg-white/20 backdrop-blur-md">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 text-white"><path d="M14.531 12.469 6.619 20.38a1 1 0 1 1-3-3l7.912-7.912"/><path d="M15.686 4.314A12.5 12.5 0 0 0 5.461 2.958 1 1 0 0 0 5.58 4.71a22 22 0 0 1 6.318 3.393"/><path d="M17.7 3.7a1 1 0 0 0-1.4 0l-4.6 4.6a1 1 0 0 0 0 1.4l2.6 2.6a1 1 0 0 0 1.4 0l4.6-4.6a1 1 0 0 0 0-1.4z"/><path d="M19.686 8.314a12.5 12.5 0 0 1 1.356 10.225 1 1 0 0 1-1.751-.119 22 22 0 0 0-3.393-6.319"/><path d="m18.31 11.69-7.912 7.912a1 1 0 1 1-3-3l7.912-7.912"/></svg>
          </div>
        </div>
        <div class="p-6">
          <h3 class="mb-3 font-heading text-xl font-bold text-foreground">
            {services[0].title}
          </h3>
          <p class="text-sm leading-relaxed text-muted-foreground">
            {services[0].description}
          </p>
        </div>
      </div>

      <div
        class="group relative overflow-hidden rounded-2xl bg-card shadow-sm transition-all duration-300 hover:shadow-xl"
      >
        <div class="relative h-48 overflow-hidden">
          <Image
            src={services[1].image}
            alt={services[1].title}
            class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent"></div>
          <div class="absolute bottom-4 left-4 flex h-12 w-12 items-center justify-center rounded-xl bg-white/20 backdrop-blur-md">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 text-white"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </div>
        </div>
        <div class="p-6">
          <h3 class="mb-3 font-heading text-xl font-bold text-foreground">
            {services[1].title}
          </h3>
          <p class="text-sm leading-relaxed text-muted-foreground">
            {services[1].description}
          </p>
        </div>
      </div>

      <div
        class="group relative overflow-hidden rounded-2xl bg-card shadow-sm transition-all duration-300 hover:shadow-xl"
      >
        <div class="relative h-48 overflow-hidden">
          <Image
            src={services[2].image}
            alt={services[2].title}
            class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent"></div>
          <div class="absolute bottom-4 left-4 flex h-12 w-12 items-center justify-center rounded-xl bg-white/20 backdrop-blur-md">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 text-white"><path d="M2 20a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8l-7 5V8l-7 5V4a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/><path d="M17 18h1"/><path d="M12 18h1"/><path d="M7 18h1"/></svg>
          </div>
        </div>
        <div class="p-6">
          <h3 class="mb-3 font-heading text-xl font-bold text-foreground">
            {services[2].title}
          </h3>
          <p class="text-sm leading-relaxed text-muted-foreground">
            {services[2].description}
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
