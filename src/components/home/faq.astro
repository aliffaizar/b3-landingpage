---
const faqs = [
  {
    question: "Apa itu limbah B3?",
    answer: "Limbah B3 adalah sisa kegiatan yang mengandung zat berbahaya yang jika tidak dikelola secara profesional, dapat memicu sanksi hukum berat dan kerusakan lingkungan permanen."
  },
  {
    question: "Bagaimana kami melindungi Anda dari sanksi hukum?",
    answer: "Kami memiliki izin pengangkutan resmi dari KLHK dan Kemenhub. Setiap perjalanan disertai dokumentasi legal lengkap, memastikan operasional Anda selalu berada dalam koridor hukum yang aman."
  },
  {
    question: "Bagaimana sistem pelaporan manifest digital kami?",
    answer: "Lupakan administrasi yang rumit. Sistem kami terintegrasi penuh dengan FESTRONIK KLHK, memberikan Anda pelaporan manifest real-time yang akurat, transparan, dan siap audit kapan saja."
  },
  {
    question: "Jenis limbah industri apa saja yang kami tangani?",
    answer: "Mulai dari limbah medis infeksius hingga limbah pertambangan (tailing) dan sludge industri manufaktur. Setiap kategori ditangani dengan armada khusus yang dirancang untuk mitigasi risiko maksimal."
  },
  {
    question: "Seberapa cepat tim kami merespon kebutuhan Anda?",
    answer: "Waktu adalah aset. Kami memberikan konsultasi strategi pengelolaan limbah dalam waktu kurang dari 24 jam untuk memastikan operasional bisnis Anda tetap berjalan lancar."
  }
  ];
---

<section id="faq" class="py-24">
  <div class="mx-auto max-w-4xl px-8">
    <div class="mb-16 text-center">
      <h2 class="mb-4 font-heading text-3xl font-bold tracking-tight text-foreground lg:text-4xl">
        Pertanyaan Umum (FAQ)
      </h2>
      <p class="mx-auto mb-6 max-w-2xl text-muted-foreground">
        Temukan jawaban untuk pertanyaan yang paling sering diajukan mengenai layanan pengelolaan limbah B3 kami.
      </p>
      <div class="mx-auto h-1 w-20 rounded-full bg-primary"></div>
    </div>

    <div class="space-y-4">
      {
        faqs.map((faq) => (
          <details class="group rounded-2xl border border-foreground/10 p-6 transition-all duration-300 open:shadow-md">
            <summary class="flex cursor-pointer list-none items-center justify-between font-heading text-lg font-semibold text-foreground">
              {faq.question}
              <span class="ml-4 flex-shrink-0 transition-transform duration-300 group-open:rotate-180">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="h-5 w-5 text-primary"
                >
                  <path d="m6 9 6 6 6-6" />
                </svg>
              </span>
            </summary>
            <div class="mt-4 border-t border-foreground/5 pt-4 text-muted-foreground leading-relaxed">
              {faq.answer}
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>

<style>
  /* Remove default arrow in Chrome/Safari */
  summary::-webkit-details-marker {
    display: none;
  }
</style>
